local function createButton(parent,text,y,callback)
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(1,-20,0,30)
    b.Position = UDim2.new(0,10,0,y)
    b.BackgroundColor3 = buttonColor
    b.TextColor3 = textColor
    b.Text = text
    b.Font = Enum.Font.GothamBold
    b.TextSize = 14
    b.BorderSizePixel = 0
    b.Parent = parent
    b.MouseEnter:Connect(function() b.BackgroundColor3 = buttonHoverColor end)
    b.MouseLeave:Connect(function() b.BackgroundColor3 = buttonColor end)
    b.MouseButton1Click:Connect(callback)
end

-- ======================
-- CREAR MENÚS
-- ======================
local y = 10
for _, menu in ipairs(menuOrder) do
    createButton(leftFrame, menu, y, function()
        rightFrame:ClearAllChildren()

        local title = Instance.new("TextLabel", rightFrame)
        title.Size = UDim2.new(1,0,0,30)
        title.BackgroundTransparency = 1
        title.Text = menu
        title.TextColor3 = textColor
        title.Font = Enum.Font.GothamBold
        title.TextSize = 18

        local oy = 40
        for _, opt in ipairs(menuData[menu]) do
            createButton(rightFrame, opt, oy, function()
                -- ================== PANELS ==================
                if menu == "PANELS" then
                    if opt == "ESP PANELS" then
                        espEnabled = not espEnabled
                        if espEnabled then
                            scanPanels()
                            scanConnection = RunService.RenderStepped:Connect(scanPanels)
                        else
                            if scanConnection then scanConnection:Disconnect() end
                            clearESP()
                        end
                    elseif opt == "AUTO COLLECT PANELS" then
                        loadstring(game:HttpGet("https://raw.githubusercontent.com/davidsebas348-hub/Text10/refs/heads/main/Text10.lua", true))()
                    elseif opt == "AUTO PONER PANELS" then
                        loadstring(game:HttpGet("https://raw.githubusercontent.com/davidsebas348-hub/Text12/refs/heads/main/Text12", true))()
                    elseif opt == "WIN" then
                        loadstring(game:HttpGet("https://raw.githubusercontent.com/davidsebas348-hub/Text13/refs/heads/main/Text13.lua", true))()
                        title.Text = "PANELS/WIN"
                    end

                -- ================== GUARD ==================
                elseif menu == "GUARD" then
                    if opt == "TRAP GUARDIA" then TrapActive = not TrapActive
                    elseif opt == "ESP GUARDIAS" then ESPGuardActive = not ESPGuardActive
                    end

                -- ================== TP/TEAM ==================
                elseif menu == "TP/TEAM" then
                    if opt == "TP GUI" then
                        loadstring(game:HttpGet("https://raw.githubusercontent.com/davidsebas348-hub/Text3/refs/heads/main/Text3", true))()
                    elseif opt == "REVIVE TEAM GUI" then
                        loadstring(game:HttpGet("https://raw.githubusercontent.com/davidsebas348-hub/Revive-gui/refs/heads/main/Op_gui.lua", true))()
                    elseif opt == "AUTO WIN (TEAM)" then
                        loadstring(game:HttpGet("https://raw.githubusercontent.com/davidsebas348-hub/Text6/refs/heads/main/Text6.lua", true))()
                        screenGui:Destroy() -- cerrar GUI al activar Auto Win
                    end

                -- ================== MISC ==================
                elseif menu == "MISC" then
                    if opt == "LocalPlayer" then
                        loadstring(game:HttpGet("https://raw.githubusercontent.com/davidsebas348-hub/Text8/refs/heads/main/Text8.lua", true))()
                    end
                end
            end)
            oy += 40
        end
    end)
    y += 40
end

