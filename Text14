local function addPanelESP(panel)
    if panel:FindFirstChild("PanelESP") then return end
    if not panel:IsA("BasePart") and not panel:FindFirstChildWhichIsA("BasePart") then return end

    local h = Instance.new("Highlight")
    h.Name = "PanelESP"
    h.FillColor = Color3.fromRGB(0,255,0)
    h.FillTransparency = 0.6
    h.OutlineColor = Color3.fromRGB(0,255,0)
    h.Parent = panel

    table.insert(highlights, h)
end

local function scanPanels()
    local folder = Workspace:FindFirstChild("PanelSpawn")
    if not folder then return end
    for _, p in ipairs(folder:GetDescendants()) do
        if p:FindFirstChildWhichIsA("ProximityPrompt") then
            addPanelESP(p)
        end
    end
end

local function clearESP()
    for _, h in ipairs(highlights) do
        if h and h.Parent then h:Destroy() end
    end
    table.clear(highlights)
end

-- ======================
-- FUNCIONES GUARD
-- ======================
local function GetNPCGuard()
	for _, obj in pairs(workspace:GetDescendants()) do
		if obj:IsA("Model")
		and obj:FindFirstChildOfClass("Humanoid")
		and obj:FindFirstChild("HumanoidRootPart")
		and not Players:GetPlayerFromCharacter(obj) then
			return obj
		end
	end
	return nil
end

local function SetupBodyPosition(root)
	local bp = root:FindFirstChild("TrapBP")
	if not bp then
		bp = Instance.new("BodyPosition")
		bp.Name = "TrapBP"
		bp.MaxForce = Vector3.new(1e5,1e5,1e5)
		bp.D = 30
		bp.P = 5000
		bp.Parent = root
	end
	return bp
end

local function DisableTrap(root)
	local bp = root:FindFirstChild("TrapBP")
	if bp then bp:Destroy() end
end

local function AddBoxNPC(npc)
	if npc:FindFirstChild("BoxESP") then return end
	local h = Instance.new("Highlight")
	h.Name = "BoxESP"
	h.FillColor = Color3.fromRGB(0,120,255)
	h.FillTransparency = 0.5
	h.OutlineColor = Color3.fromRGB(0,120,255)
	h.OutlineTransparency = 0
	h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
	h.Parent = npc
end

local function RemoveBoxNPC(npc)
	local h = npc:FindFirstChild("BoxESP")
	if h then h:Destroy() end
end

-- ======================
-- LOOP PRINCIPAL
-- ======================
RunService.RenderStepped:Connect(function()
	local char = player.Character
	if not char then return end
	local root = char:FindFirstChild("HumanoidRootPart")
	if not root then return end

	if TrapActive then
		local guard = GetNPCGuard()
		if guard and guard:FindFirstChild("HumanoidRootPart") then
			root.CFrame = guard.HumanoidRootPart.CFrame + Vector3.new(0,heightOffset,0)
			local bp = SetupBodyPosition(root)
			bp.Position = guard.HumanoidRootPart.Position + Vector3.new(0,heightOffset,0)
		else
			DisableTrap(root)
		end
	else
		DisableTrap(root)
	end

	for _, obj in pairs(workspace:GetDescendants()) do
		if obj:IsA("Model")
		and obj:FindFirstChild("Humanoid")
		and obj:FindFirstChild("HumanoidRootPart")
		and not Players:GetPlayerFromCharacter(obj) then
			if ESPGuardActive then
				AddBoxNPC(obj)
			else
				RemoveBoxNPC(obj)
			end
		end
	end
end)

